# Discord bot
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_GUILD_ID=your-guild-id-here          # guild for instant slash command sync

# AI services (Anthropic required; transcription picks the first available)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=                        # preferred Whisper backend
REPLICATE_API_TOKEN=                   # fallback Whisper backend

# Transcript web UI (required — blocks all access if unset)
WEB_PASSWORD=choose-a-strong-password
WEB_PORT=8080                          # default
